        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_14",
          "japaneseText": "「枯れ木に花を咲かせましょう。」",
          "translation": "让枯树开花吧。",
          "rubySegments": [
            {
              "text": "「枯れ木に",
              "ruby": "「かれきに",
