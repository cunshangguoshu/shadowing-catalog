        },
        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_11",
          "japaneseText": "怒ったじいさんは、シロを殺してしまいました。",
          "translation": "生气的老爷爷，把小白给杀死了。",
          "rubySegments": [
            {
              "text": "怒った",
              "ruby": "おこった",
              "translation": "生气的"
            },
            {
              "text": "じいさんは、",
              "ruby": null,
              "translation": "老爷爷、"
            },
            {
              "text": "シロを",
              "ruby": null,
              "translation": "把小白"
            },
            {
              "text": "殺してしまいました。",
              "ruby": "ころしてしまいました。",
              "translation": "给杀死了。"
            }
