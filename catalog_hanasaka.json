        },
        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_13",
          "japaneseText": "ある日、おじいさんが枯れ木に灰をまきました。",
          "translation": "有一天，老爷爷把灰撒在了枯树上。",
          "rubySegments": [
            {
              "text": "ある日、",
              "ruby": "あるひ、",
              "translation": "有一天、"
            },
            {
              "text": "おじいさんが",
              "ruby": null,
              "translation": "老爷爷"
