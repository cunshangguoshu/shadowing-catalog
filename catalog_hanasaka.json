        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_17",
          "japaneseText": "おじいさんは、たくさんのごほうびをもらいました。",
          "translation": "老爷爷得到了很多的赏赐。",
          "rubySegments": [
            {
              "text": "おじいさんは、",
