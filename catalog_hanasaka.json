          "audioFileName": "hanasaka_16",
          "japaneseText": "通りかかったお殿様は、たいそう喜びました。",
          "translation": "路过的领主，非常高兴。",
          "rubySegments": [
            {
              "text": "通りかかった",
              "ruby": "とおりかかった",
