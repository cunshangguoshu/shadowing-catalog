        },
        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_12",
          "japaneseText": "悲しんだおじいさんは、残った灰を大切に持ち帰りました。",
          "translation": "伤心的老爷爷，把剩下的灰烬小心翼翼地带回了家。",
          "rubySegments": [
            {
              "text": "悲しんだ",
              "ruby": "かなしんだ",
              "translation": "伤心的"
            },
            {
              "text": "おじいさんは、",
              "ruby": null,
              "translation": "老爷爷、"
            },
            {
              "text": "残った",
              "ruby": "のこった",
              "translation": "把剩下的"
            },
            {
              "text": "灰を",
              "ruby": "はいを",
              "translation": "灰烬"
            },
            {
              "text": "大切に",
              "ruby": "たいせつに",
              "translation": "小心翼翼地"
            },
            {
              "text": "持ち帰りました。",
              "ruby": "もちかえりました。",
              "translation": "带回去了。"
            }
