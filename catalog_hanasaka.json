{
  "packs": [
    {
      "id": "pack_hanasaka",
      "title": "花咲か爺さん",
      "icon": "🌸",
      "type": "shadowing",
      "cards": [
        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_01",
          "japaneseText": "むかしむかし、あるところに、やさしいおじいさんとおばあさんがいました。",
          "translation": "很久很久以前，在某个地方，生活着善良的老爷爷和老奶奶。",
          "rubySegments": [
            {
              "text": "むかしむかし、",
              "ruby": null,
              "translation": "很久很久以前，"
            },
            {
              "text": "あるところに、",
              "ruby": null,
              "translation": "在某个地方，"
            },
            {
              "text": "やさしい",
              "ruby": null,
              "translation": "善良的"
            },
            {
              "text": "おじいさんと",
              "ruby": null,
              "translation": "老爷爷和"
            },
            {
              "text": "おばあさんがいました。",
              "ruby": null,
              "translation": "老奶奶生活着。"
            }
          ]
        },
        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_02",
          "japaneseText": "ふたりは、「シロ」という名前の犬をかっていました。",
          "translation": "两人养了一只名叫\"小白\"的狗。",
          "rubySegments": [
            {
              "text": "ふたりは、",
              "ruby": null,
              "translation": "两人、"
            },
            {
              "text": "「シロ」という",
              "ruby": null,
              "translation": "名叫\"小白\"的"
            },
            {
              "text": "名前の",
              "ruby": "なまえの",
              "translation": "名字的"
            },
            {
              "text": "犬を",
              "ruby": "いぬを",
              "translation": "狗"
            },
            {
              "text": "かっていました。",
              "ruby": null,
              "translation": "养着。"
            }
          ]
        },
        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_03",
          "japaneseText": "ふたりは、シロをとてもかわいがっていました。",
          "translation": "两人非常疼爱小白。",
          "rubySegments": [
            {
              "text": "ふたりは、",
              "ruby": null,
              "translation": "两人、"
            },
            {
              "text": "シロを",
              "ruby": null,
              "translation": "对小白"
            },
            {
              "text": "とても",
              "ruby": null,
              "translation": "非常地"
            },
            {
              "text": "かわいがっていました。",
              "ruby": null,
              "translation": "疼爱着。"
            }
          ]
        },
        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_04",
          "japaneseText": "ある日、おじいさんが畑にいると、シロがやってきて、なきだしました。",
          "translation": "有一天，老爷爷在田里时，小白跑了过来，叫了起来。",
          "rubySegments": [
            {
              "text": "ある日、",
              "ruby": "あるひ、",
              "translation": "有一天、"
            },
            {
              "text": "おじいさんが",
              "ruby": null,
              "translation": "老爷爷"
            },
            {
              "text": "畑にいると、",
              "ruby": "はたけにいると、",
              "translation": "在田里的时候、"
            },
            {
              "text": "シロがやってきて、",
              "ruby": null,
              "translation": "小白跑了过来、"
            },
            {
              "text": "なきだしました。",
              "ruby": null,
              "translation": "叫了起来。"
            }
          ]
        },
        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_05",
          "japaneseText": "「ここ掘れワンワン、ここ掘れワンワン」",
          "translation": "挖这里汪汪，挖这里汪汪！",
          "rubySegments": [
            {
              "text": "「ここ掘れ",
              "ruby": "「ここほれ",
              "translation": "「挖这里"
            },
            {
              "text": "ワンワン、",
              "ruby": null,
              "translation": "汪汪、"
            },
            {
              "text": "ここ掘れ",
              "ruby": "ここほれ",
              "translation": "挖这里"
            },
            {
              "text": "ワンワン」",
              "ruby": "」",
              "translation": "汪汪」"
            }
          ]
        },
        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_06",
          "japaneseText": "おじいさんが、そこをくわで掘ってみると、",
          "translation": "老爷爷用锄头在那里试着挖了一下，",
          "rubySegments": [
            {
              "text": "おじいさんが、",
              "ruby": null,
              "translation": "老爷爷、"
            },
            {
              "text": "そこを",
              "ruby": null,
              "translation": "在那里"
            },
            {
              "text": "くわで",
              "ruby": null,
              "translation": "用锄头"
            },
            {
              "text": "掘ってみると、",
              "ruby": "ほってみると、",
              "translation": "试着挖了一下、"
            }
          ]
        },
        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_07",
          "japaneseText": "カチンと音がして、大判小判がざくざくと出てきました。",
          "translation": "发出\"咔哒\"一声，大金币和小金币哗啦哗啦地出来了。",
          "rubySegments": [
            {
              "text": "カチンと",
              "ruby": null,
              "translation": "咔哒一声"
            },
            {
              "text": "音がして、",
              "ruby": "おとがして、",
              "translation": "发出声音、"
            },
            {
              "text": "大判小判が",
              "ruby": "おおばんこばんが",
              "translation": "大金币和小金币"
            },
            {
              "text": "ざくざくと",
              "ruby": null,
              "translation": "哗啦哗啦地"
            },
            {
              "text": "出てきました。",
              "ruby": "でてきました。",
              "translation": "出来了。"
            }
          ]
        },
        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_08",
          "japaneseText": "「これはたまげた。」おじいさんとおばあさんは大喜びです。",
          "translation": "这可真让人吃惊。老爷爷和老奶奶非常高兴。",
          "rubySegments": [
            {
              "text": "「これはたまげた。」",
              "ruby": null,
              "translation": "这可真让人吃惊。"
            },
            {
              "text": "おじいさんとおばあさんは",
              "ruby": null,
              "translation": "老爷爷和老奶奶"
            },
            {
              "text": "大喜びです。",
              "ruby": "おおよろこびです。",
              "translation": "非常高兴。"
            }
          ]
        },
        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_09",
          "japaneseText": "となりの欲張りじいさんが、シロを無理やり連れて行きました。",
          "translation": "隔壁贪婪的老爷爷，硬把小白带走了。",
          "rubySegments": [
            {
              "text": "となりの",
              "ruby": null,
              "translation": "隔壁的"
            },
            {
              "text": "欲張りじいさんが、",
              "ruby": "よくばりじいさんが、",
              "translation": "贪婪的老爷爷、"
            },
            {
              "text": "シロを",
              "ruby": null,
              "translation": "把小白"
            },
            {
              "text": "無理やり",
              "ruby": "むりやり",
              "translation": "硬是"
            },
            {
              "text": "連れて行きました。",
              "ruby": "つれていきました。",
              "translation": "带走了。"
            }
          ]
        },
        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_10",
          "japaneseText": "しかし、出てきたのはゴミばかりでした。",
          "translation": "但是，挖出来的全是垃圾。",
          "rubySegments": [
            {
              "text": "しかし、",
              "ruby": null,
              "translation": "但是、"
            },
            {
              "text": "出てきたのは",
              "ruby": "でてきたのは",
              "translation": "出来的东西"
            },
            {
              "text": "ゴミばかりでした。",
              "ruby": null,
              "translation": "全是垃圾。"
            }
