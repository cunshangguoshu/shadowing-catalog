          "rubySegments": [
            {
              "text": "ふたりは、",
              "ruby": null,
              "translation": "两人、"
            },
            {
              "text": "「シロ」という",
              "ruby": null,
              "translation": "名叫\"小白\"的"
            },
            {
              "text": "名前の",
              "ruby": "なまえの",
              "translation": "名字的"
            },
