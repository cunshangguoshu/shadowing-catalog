        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_05",
          "japaneseText": "「ここ掘れワンワン、ここ掘れワンワン」",
          "translation": "挖这里汪汪，挖这里汪汪！",
