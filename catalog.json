    {
      "id": "pack_gongitsune",
      "title": "ごんぎつね",
      "icon": "🦊",
      "type": "shadowing",
      "cards": [
        {
          "videoName": null,
          "coverImageName": null,
          "audioFileName": null,
          "coverImageURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_cover.png",
          "audioFileURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_01.mp3",
          "japaneseText": "ごんは、ひとりぼっちの小狐で、森の中に住んでいました。",
          "translation": "阿权是一只孤零零的小狐狸，住在森林里。",
          "rubySegments": [
            {
              "text": "ごんは、",
              "ruby": "ごんは、",
              "translation": "阿权，"
            },
            {
              "text": "ひとりぼっちの小狐で、",
              "ruby": "ひとりぼっちのこぎつねで、",
              "translation": "是一只孤零零的小狐狸，"
            },
            {
              "text": "森の中に",
              "ruby": "もりのなかに",
              "translation": "在森林里"
            },
            {
              "text": "住んでいました。",
              "ruby": "すんでいました。",
              "translation": "住着。"
