          "audioFileURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_02.mp3",
          "japaneseText": "村へ出てきては、いろいろないたずらをしました。",
          "translation": "他一跑到村子里，就干各种各样的恶作剧。",
          "rubySegments": [
            {
              "text": "村へ",
              "ruby": "むらへ",
              "translation": "往村子里"
            },
            {
              "text": "出てきては、",
              "ruby": "でてきては、",
              "translation": "一跑出来，"
            },
            {
              "text": "いろいろな",
              "ruby": "いろいろな",
              "translation": "各种各样的"
            },
            {
              "text": "いたずらをしました。",
              "ruby": "いたずらをしました。",
              "translation": "恶作剧就干。"
            }
          ]
        },
        {
          "videoName": null,
          "coverImageName": null,
          "audioFileName": null,
          "coverImageURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_cover.png",
          "audioFileURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_03.mp3",
          "japaneseText": "ある秋のこと、兵十が川で魚をとっていました。",
          "translation": "有一个秋天，兵十在河里捕鱼。",
          "rubySegments": [
            {
              "text": "ある秋のこと、",
              "ruby": "あるあきのこと、",
              "translation": "有一个秋天，"
            },
            {
              "text": "兵十が",
              "ruby": "ひょうじゅうが",
              "translation": "兵十"
            },
            {
              "text": "川で魚を",
              "ruby": "かわでさかなを",
              "translation": "在河里把鱼"
            },
            {
              "text": "とっていました。",
              "ruby": "とっていました。",
              "translation": "捕着。"
            }
          ]
        },
        {
          "videoName": null,
          "coverImageName": null,
          "audioFileName": null,
          "coverImageURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_cover.png",
          "audioFileURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_04.mp3",
          "japaneseText": "ごんは、兵十の魚やうなぎを、川の中へ投げこんでしまいました。",
          "translation": "阿权把兵十的鱼和鳗鱼，全都扔进了河里。",
          "rubySegments": [
            {
              "text": "ごんは、",
              "ruby": "ごんは、",
              "translation": "阿权，"
            },
            {
              "text": "兵十の魚やうなぎを、",
              "ruby": "ひょうじゅうのさかなやうなぎを、",
              "translation": "把兵十的鱼和鳗鱼，"
            },
            {
              "text": "川の中へ",
              "ruby": "かわのなかへ",
              "translation": "往河里"
            },
            {
              "text": "投げこんでしまいました。",
              "ruby": "なげこんでしまいました。",
              "translation": "全都扔了进去。"
            }
          ]
        },
        {
          "videoName": null,
          "coverImageName": null,
          "audioFileName": null,
          "coverImageURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_cover.png",
          "audioFileURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_05.mp3",
          "japaneseText": "それから十日ほどたって、兵十のお母さんが死にました。",
          "translation": "在那之后大约过了十天，兵十的母亲去世了。",
          "rubySegments": [
            {
              "text": "それから",
              "ruby": "それから",
              "translation": "在那之后"
            },
            {
              "text": "十日ほどたって、",
              "ruby": "とおかほどたって、",
              "translation": "大约过了十天，"
            },
            {
              "text": "兵十のお母さんが",
              "ruby": "ひょうじゅうのおかあさんが",
              "translation": "兵十的母亲"
            },
            {
              "text": "死にました。",
              "ruby": "しにました。",
              "translation": "去世了。"
            }
          ]
        },
        {
          "videoName": null,
          "coverImageName": null,
          "audioFileName": null,
          "coverImageURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_cover.png",
          "audioFileURL": "https://raw.githubusercontent.com/cunshangguoshu/shadowing-catalog/main/media/gongitsune_06.mp3",
          "japaneseText": "「ああ、うなぎが食べたいと思いながら、死んだんだろう。あんないたずらをしなけりゃよかった。」",
          "translation": "“唉，一定是想着好想吃鳗鱼，死去的吧。要是不搞那种恶作剧就好了。”",
          "rubySegments": [
            {
              "text": "「ああ、",
              "ruby": "「ああ、",
              "translation": "「唉，"
            },
            {
              "text": "うなぎが食べたいと",
              "ruby": "うなぎがたべたいと",
              "translation": "好想吃鳗鱼"
            },
            {
              "text": "思いながら、",
              "ruby": "おもいながら、",
              "translation": "一定是这样想着，"
            },
