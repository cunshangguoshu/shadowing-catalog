      "cards": [
        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_01",
          "japaneseText": "むかしむかし、あるところに、やさしいおじいさんとおばあさんがいました。",
          "translation": "很久很久以前，在某个地方，生活着善良的老爷爷和老奶奶。",
          "rubySegments": [
            {
              "text": "むかしむかし、",
              "ruby": null,
              "translation": "很久很久以前，"
            },
            {
              "text": "あるところに、",
              "ruby": null,
              "translation": "在某个地方，"
            },
            {
              "text": "やさしい",
              "ruby": null,
              "translation": "善良的"
