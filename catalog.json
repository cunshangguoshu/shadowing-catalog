        },
        {
          "videoName": null,
          "coverImageName": "HanasakaCover",
          "audioFileName": "hanasaka_04",
          "japaneseText": "ある日、おじいさんが畑にいると、シロがやってきて、なきだしました。",
          "translation": "有一天，老爷爷在田里时，小白跑了过来，叫了起来。",
          "rubySegments": [
            {
              "text": "ある日、",
              "ruby": "あるひ、",
              "translation": "有一天、"
            },
            {
              "text": "おじいさんが",
              "ruby": null,
              "translation": "老爷爷"
            },
            {
              "text": "畑にいると、",
              "ruby": "はたけにいると、",
              "translation": "在田里的时候、"
